// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  ADMIN
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bookmarks        News[]
  profile          UserProfile?
  reportsSubmitted HoaxReport[] @relation("ReporterRelation")
  reportsReviewed  HoaxReport[] @relation("ReviewerRelation")

  @@map("users")
}

model UserProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique @map("user_id")
  username    String?
  bio         String?  @db.Text
  phoneNumber String?  @map("phone_number")
  address     String?  @db.Text
  dob         String?
  occupation  String?
  interests   String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model News {
  id             Int      @id @default(autoincrement())
  title          String   @db.VarChar(500)
  link           String   @db.VarChar(1000)
  contentSnippet String?  @db.Text @map("content_snippet")
  isoDate        String?  @map("iso_date")
  imageLarge     String?  @db.VarChar(1000) @map("image_large")
  imageSmall     String?  @db.VarChar(1000) @map("image_small")
  createdAt      DateTime @default(now()) @map("created_at")

  userId Int?  @map("user_id")
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("news")
}

model HoaxReport {
  id        Int          @id @default(autoincrement())
  category  String
  url       String       @db.VarChar(1000)
  notes     String?      @db.Text
  imagePath String?      @db.VarChar(1000) @map("image_path")
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  reporterId   Int?  @map("reporter_id")
  reporter     User? @relation("ReporterRelation", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedById Int?  @map("reviewed_by_id")
  reviewedBy   User? @relation("ReviewerRelation", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@map("hoax_reports")
}
